<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Настройки приватности - czhmass.com</title>
    
    <script src="https://www.gstatic.com/firebasejs/9.0.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.0.0/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.0.0/firebase-auth-compat.js"></script>
    
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
        }

        .navbar {
            background: white;
            padding: 16px 24px;
            border-radius: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #1877f2;
            text-decoration: none;
        }

        .btn {
            background: #1877f2;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 15px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn:hover {
            background: #166fe5;
            transform: translateY(-1px);
        }

        .btn-back {
            background: #e4e6eb;
            color: #050505;
        }

        .settings-card {
            background: white;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        }

        .settings-title {
            font-size: 28px;
            font-weight: 700;
            color: #1c1e21;
            margin-bottom: 8px;
        }

        .settings-subtitle {
            color: #65676b;
            margin-bottom: 40px;
        }

        .privacy-section {
            margin-bottom: 40px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #1c1e21;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .privacy-option {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 12px;
            margin-bottom: 15px;
            transition: all 0.2s;
        }

        .privacy-option:hover {
            background: #edf2f7;
        }

        .option-info {
            flex: 1;
        }

        .option-title {
            font-weight: 600;
            margin-bottom: 5px;
            color: #1c1e21;
        }

        .option-description {
            color: #65676b;
            font-size: 14px;
            line-height: 1.5;
        }

        .toggle-switch {
            position: relative;
            display: inline-block;
            width: 60px;
            height: 30px;
            margin-left: 20px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 34px;
        }

        .toggle-slider:before {
            position: absolute;
            content: "";
            height: 22px;
            width: 22px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked + .toggle-slider {
            background-color: #38a169;
        }

        input:checked + .toggle-slider:before {
            transform: translateX(30px);
        }

        .message {
            padding: 14px;
            border-radius: 8px;
            margin: 16px 0;
            display: none;
            font-size: 14px;
        }

        .success {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

        .error {
            background: #fee2e2;
            color: #7f1d1d;
            border: 1px solid #fecaca;
        }

        .danger-zone {
            background: #fed7d7;
            border: 2px solid #feb2b2;
            padding: 25px;
            border-radius: 12px;
            margin-top: 40px;
        }

        .danger-title {
            color: #9b2c2c;
            margin-bottom: 15px;
        }
        
        .loading {
            text-align: center;
            padding: 40px;
            color: #65676b;
        }
    </style>
</head>
<body>
    <div class="container">
        <nav class="navbar">
            <a href="feed.html" class="logo">czhmass.com</a>
            <button class="btn btn-back" onclick="goBack()">← Назад в профиль</button>
        </nav>

        <div class="settings-card">
            <h1 class="settings-title">🔒 Настройки приватности</h1>
            <p class="settings-subtitle">Управляйте тем, какую информацию видят другие пользователи</p>
            
            <div id="loading" class="loading" style="display: none;">Загрузка настроек...</div>
            
            <!-- КТО ВИДИТ ПРОФИЛЬ -->
            <div class="privacy-section" id="privacySettings">
                <h2 class="section-title">👁️ Видимость профиля</h2>
                
                <div class="privacy-option">
                    <div class="option-info">
                        <div class="option-title">Показывать email в профиле</div>
                        <div class="option-description">
                            По умолчанию email видят только администраторы. 
                            Если включить - ваш email будет виден всем.
                        </div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" id="toggleEmail">
                        <span class="toggle-slider"></span>
                    </label>
                </div>

                <div class="privacy-option">
                    <div class="option-info">
                        <div class="option-title">Разрешить упоминания</div>
                        <div class="option-description">
                            Другие пользователи смогут упоминать вас в постах (@ваш_юзернейм)
                        </div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" id="toggleMentions">
                        <span class="toggle-slider"></span>
                    </label>
                </div>

                <div class="privacy-option">
                    <div class="option-info">
                        <div class="option-title">Показывать профиль в поиске</div>
                        <div class="option-description">
                            Ваш профиль будет появляться в результатах поиска других пользователей
                        </div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" id="toggleProfileVisible" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- ПРОФИЛЬНЫЕ ДАННЫЕ -->
            <div class="privacy-section">
                <h2 class="section-title">📊 Профильная информация</h2>
                
                <div class="privacy-option">
                    <div class="option-info">
                        <div class="option-title">Показывать количество постов</div>
                        <div class="option-description">
                            Отображать статистику постов в вашем профиле
                        </div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" id="togglePostsCount" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>

                <div class="privacy-option">
                    <div class="option-info">
                        <div class="option-title">Показывать дату регистрации</div>
                        <div class="option-description">
                            Отображать, когда вы зарегистрировались на сайте
                        </div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" id="toggleJoinDate" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- ОПАСНАЯ ЗОНА -->
            <div class="danger-zone">
                <h3 class="danger-title">⚠️ Конфиденциальность данных</h3>
                <p style="color: #9b2c2c; margin-bottom: 15px;">
                    Ваш email: <strong id="userEmail">загрузка...</strong>
                </p>
                <p style="color: #744210; margin-bottom: 20px;">
                    Администраторы всегда видят полную информацию для модерации.
                </p>
                <button class="btn" style="background: #e53e3e;" onclick="downloadMyData()">
                    📥 Скачать мои данные
                </button>
            </div>

            <div style="margin-top: 30px; display: flex; gap: 15px;">
                <button class="btn btn-back" onclick="cancelSettings()">Отмена</button>
                <button class="btn" onclick="savePrivacySettings()" id="saveBtn">Сохранить настройки</button>
            </div>

            <div id="message" class="message"></div>
        </div>
    </div>

    <script>
        // ===== FIREBASE КОНФИГ =====
        const firebaseConfig = {
            apiKey: "AIzaSyBn-gM0CM2NPMGZ6OpytlPkiIOSIm54hcY",
            authDomain: "czhmass.firebaseapp.com",
            projectId: "czhmass",
            storageBucket: "czhmass.firebasestorage.app",
            messagingSenderId: "1064257019843",
            appId: "1:1064257019843:web:65488b45be2f86838ca776"
        };

        // ===== ИНИЦИАЛИЗАЦИЯ =====
        let db, auth;
        let currentUserId = null;
        let originalSettings = {}; // Сохраняем оригинальные настройки

        if (!firebase.apps.length) {
            firebase.initializeApp(firebaseConfig);
        }

        db = firebase.firestore();
        auth = firebase.auth();

        // ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
        function showMessage(text, type) {
            const messageDiv = document.getElementById('message');
            messageDiv.textContent = text;
            messageDiv.className = 'message ' + type;
            messageDiv.style.display = 'block';
            setTimeout(() => { messageDiv.style.display = 'none'; }, 4000);
        }

        function goBack() {
            // Просто перенаправляем в профиль без сохранения
            window.location.href = 'profile.html';
        }

        function cancelSettings() {
            // Возвращаем переключатели в исходное состояние
            document.getElementById('toggleEmail').checked = originalSettings.displayEmail || false;
            document.getElementById('toggleMentions').checked = originalSettings.allowMentions !== false;
            document.getElementById('toggleProfileVisible').checked = originalSettings.profileVisible !== false;
            document.getElementById('togglePostsCount').checked = originalSettings.showPostsCount !== false;
            document.getElementById('toggleJoinDate').checked = originalSettings.showJoinDate !== false;
            
            showMessage('Настройки сброшены к исходным', 'success');
            setTimeout(goBack, 1000);
        }

        // ===== ЗАГРУЗКА НАСТРОЕК =====
        async function loadPrivacySettings() {
            const user = auth.currentUser;
            
            if (!user) {
                window.location.href = 'index.html';
                return;
            }

            try {
                // Показываем загрузку
                document.getElementById('loading').style.display = 'block';
                document.getElementById('privacySettings').style.opacity = '0.5';
                
                currentUserId = user.uid;
                document.getElementById('userEmail').textContent = user.email;

                const userDoc = await db.collection('users').doc(user.uid).get();
                
                if (userDoc.exists) {
                    const userData = userDoc.data();
                    
                    // Сохраняем оригинальные настройки
                    originalSettings = {
                        displayEmail: userData.displayEmail || false,
                        allowMentions: userData.allowMentions !== false,
                        profileVisible: userData.profileVisible !== false,
                        showPostsCount: userData.showPostsCount !== false,
                        showJoinDate: userData.showJoinDate !== false
                    };
                    
                    // Устанавливаем переключатели
                    document.getElementById('toggleEmail').checked = originalSettings.displayEmail;
                    document.getElementById('toggleMentions').checked = originalSettings.allowMentions;
                    document.getElementById('toggleProfileVisible').checked = originalSettings.profileVisible;
                    document.getElementById('togglePostsCount').checked = originalSettings.showPostsCount;
                    document.getElementById('toggleJoinDate').checked = originalSettings.showJoinDate;
                    
                    console.log('✅ Настройки приватности загружены:', originalSettings);
                }
                
                // Скрываем загрузку
                document.getElementById('loading').style.display = 'none';
                document.getElementById('privacySettings').style.opacity = '1';
                
            } catch (error) {
                console.error('Ошибка загрузки настроек:', error);
                showMessage('Ошибка загрузки настроек', 'error');
                document.getElementById('loading').style.display = 'none';
                document.getElementById('privacySettings').style.opacity = '1';
            }
        }

        // ===== СОХРАНЕНИЕ НАСТРОЕК =====
        async function savePrivacySettings() {
            if (!currentUserId) return;

            const saveBtn = document.getElementById('saveBtn');
            const originalText = saveBtn.textContent;
            saveBtn.disabled = true;
            saveBtn.textContent = 'Сохранение...';

            try {
                const settings = {
                    displayEmail: document.getElementById('toggleEmail').checked,
                    allowMentions: document.getElementById('toggleMentions').checked,
                    profileVisible: document.getElementById('toggleProfileVisible').checked,
                    showPostsCount: document.getElementById('togglePostsCount').checked,
                    showJoinDate: document.getElementById('toggleJoinDate').checked,
                    privacyUpdatedAt: firebase.firestore.FieldValue.serverTimestamp()
                };

                await db.collection('users').doc(currentUserId).update(settings);

                showMessage('✅ Настройки приватности сохранены', 'success');
                
                // Возвращаемся в профиль через 1.5 секунды
                setTimeout(() => {
                    window.location.href = 'profile.html';
                }, 1500);

            } catch (error) {
                console.error('Ошибка сохранения настроек:', error);
                showMessage('❌ Ошибка сохранения настроек: ' + error.message, 'error');
                saveBtn.disabled = false;
                saveBtn.textContent = originalText;
            }
        }

        // ===== СКАЧИВАНИЕ ДАННЫХ =====
        async function downloadMyData() {
            const user = auth.currentUser;
            if (!user) return;

            try {
                showMessage('📥 Подготовка данных...', 'success');
                
                // Получаем данные пользователя
                const userDoc = await db.collection('users').doc(user.uid).get();
                const userData = userDoc.data();
                
                // Получаем посты пользователя
                const postsSnapshot = await db.collection('posts')
                    .where('userId', '==', user.uid)
                    .orderBy('createdAt', 'desc')
                    .get();
                
                const posts = [];
                postsSnapshot.forEach(doc => {
                    const postData = doc.data();
                    // Убираем служебные поля Firebase
                    delete postData.createdAt; // Убираем Timestamp
                    posts.push({
                        id: doc.id,
                        ...postData
                    });
                });

                // Формируем объект данных
                const userExport = {
                    profile: {
                        username: userData.username,
                        email: user.email,
                        registered: userData.createdAt ? userData.createdAt.toDate().toISOString() : null,
                        postsCount: userData.postsCount || 0,
                        isAdmin: userData.isAdmin || false,
                        profileViews: userData.profileViews || 0
                    },
                    privacySettings: {
                        displayEmail: userData.displayEmail || false,
                        allowMentions: userData.allowMentions !== false,
                        profileVisible: userData.profileVisible !== false,
                        showPostsCount: userData.showPostsCount !== false,
                        showJoinDate: userData.showJoinDate !== false
                    },
                    posts: posts,
                    exportDate: new Date().toISOString(),
                    totalPosts: posts.length
                };

                // Создаем и скачиваем файл
                const dataStr = JSON.stringify(userExport, null, 2);
                const dataBlob = new Blob([dataStr], { type: 'application/json' });
                const url = URL.createObjectURL(dataBlob);
                
                const link = document.createElement('a');
                link.href = url;
                link.download = `czhmass-data-${userData.username}-${new Date().toISOString().split('T')[0]}.json`;
                document.body.appendChild(link);
                link.click();
                
                // Очищаем URL через 1 минуту
                setTimeout(() => {
                    URL.revokeObjectURL(url);
                    document.body.removeChild(link);
                }, 60000);
                
                showMessage('✅ Данные успешно скачаны', 'success');

            } catch (error) {
                console.error('Ошибка скачивания данных:', error);
                showMessage('❌ Ошибка скачивания данных: ' + error.message, 'error');
            }
        }

        // ===== ИНИЦИАЛИЗАЦИЯ =====
        auth.onAuthStateChanged((user) => {
            if (user) {
                loadPrivacySettings();
            } else {
                window.location.href = 'index.html';
            }
        });

        // Запуск при загрузке
        window.addEventListener('load', () => {
            console.log('🔒 Страница настроек приватности загружена');
            
            // Предотвращаем перезагрузку при нажатии на переключатели
            document.querySelectorAll('.toggle-switch input').forEach(toggle => {
                toggle.addEventListener('click', (e) => {
                    e.stopPropagation();
                });
            });
            
            // Предотвращаем отправку формы при нажатии Enter
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                }
            });
        });
    </script>
</body>
</html>
